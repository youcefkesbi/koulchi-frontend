# Production Environment Configuration (.env)
# Set these variables in Vercel for production deployment
# This file contains production-specific configuration
#
# OAuth is handled entirely by Supabase - no OAuth credentials needed in frontend

# App Configuration (Production)
VITE_APP_URL=https://koulchi-frontend.vercel.app

# Supabase Configuration (Production)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Environment Detection (Vercel sets this automatically)
VITE_VERCEL=1
