# Production Environment Configuration (.env)
# Set these variables in Vercel for production deployment
# This file contains production-specific OAuth credentials

# App Configuration (Production)
VITE_APP_URL=https://your-app.vercel.app

# Supabase Configuration (Production)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-production-supabase-anon-key

# OAuth Configuration (Production)
# Use production OAuth app credentials from Google Cloud Console
GOOGLE_CLIENT_ID=your-production-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-production-google-oauth-client-secret

# Environment Detection (Vercel sets this automatically)
VITE_VERCEL=1
