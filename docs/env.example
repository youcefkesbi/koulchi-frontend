# Environment Configuration Example for Koulchi Frontend
# Copy this file to .env.local for local development
# Set these variables in Vercel for production
#
# OAuth is handled entirely by Supabase - no OAuth credentials needed in frontend

# App Configuration
VITE_APP_URL=https://koulchi-frontend.vercel.app

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Environment Detection (Vercel sets this automatically)
VITE_VERCEL=1

# Development Environment (.env.local)
# VITE_APP_URL=http://localhost:3000
# VITE_SUPABASE_URL=https://your-project.supabase.co (same as production)
# VITE_SUPABASE_ANON_KEY=your-supabase-anon-key (same as production)

# Production Environment (Vercel)
# VITE_APP_URL=https://koulchi-frontend.vercel.app
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
