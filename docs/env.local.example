# Development Environment Configuration (.env.local)
# Copy this file to .env.local in your project root
# This file contains development-specific configuration
#
# OAuth is handled entirely by Supabase - no OAuth credentials needed in frontend

# App Configuration (Development)
VITE_APP_URL=http://localhost:3000

# Supabase Configuration (Development)
# Use the same Supabase project as production
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Environment Detection
VITE_VERCEL=0
