# Development Environment Configuration (.env.local)
# Copy this file to .env.local in your project root
# This file contains development-specific OAuth credentials

# App Configuration (Development)
VITE_APP_URL=http://localhost:3000

# Supabase Configuration (Development)
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=your-local-supabase-anon-key

# OAuth Configuration (Development)
# Use development OAuth app credentials from Google Cloud Console
GOOGLE_CLIENT_ID=your-development-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-development-google-oauth-client-secret

# Environment Detection
VITE_VERCEL=0
